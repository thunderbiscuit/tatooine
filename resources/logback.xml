<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender for logs info and up  -->
    <appender name="FILE_INFO_UP" class="ch.qos.logback.core.FileAppender">
        <file>
            ${HOME}/logs/tatooinefaucet.log
        </file>
        <encoder>
            <pattern>%date{yyyy-MM-dd HH:mm:ss} %-5level - %message%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Captures all loggers under the tatooine package (KotlinLogging.logger {} names by class). -->
    <logger name="com.coyotebitcoin.tatooine" level="INFO" additivity="true">
        <appender-ref ref="FILE_INFO_UP"/>
    </logger>
    <logger name="io.netty" level="INFO"/>
</configuration>
